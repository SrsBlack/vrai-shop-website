{{ 'homepage-redesign.css' | asset_url | stylesheet_tag }}
<script src="{{ 'store-redesign.js' | asset_url }}" defer></script>

{%- liquid
  assign all_collection = collections['all']
  assign all_collections_url = routes.collections_url
  if all_collections_url == blank
    assign all_collections_url = '/collections'
  endif
  assign adventure_collection = collections['adventure-series']
  assign streetwear_collection = collections['streetwear']
  assign minimal_collection = collections['minimal']
  assign coquette_collection = collections['trending-now-coquette']
  assign mood_handles = 'adventure-series,minimal,streetwear,trending-now-coquette' | split: ','
  assign now_timestamp = 'now' | date: '%s' | plus: 0
  assign fourteen_days_seconds = 1209600
  assign new_threshold = now_timestamp | minus: fourteen_days_seconds

  assign adventure_url = routes.all_products_collection_url
  if adventure_collection != blank
    assign adventure_url = adventure_collection.url
  endif

  assign streetwear_url = routes.all_products_collection_url
  if streetwear_collection != blank
    assign streetwear_url = streetwear_collection.url
  endif

  assign minimal_url = routes.all_products_collection_url
  if minimal_collection != blank
    assign minimal_url = minimal_collection.url
  endif
-%}

<section class="vrai-homepage">
  <a href="#VraiHomepageMain" class="vrai-homepage__skip-link">Skip to content</a>

  <main id="VraiHomepageMain" class="vrai-homepage__main">
    <section class="vrai-homepage__hero vrai-homepage__hero--fullscreen vrai-reveal" aria-labelledby="VraiHomepageHeroTitle">
      <div class="vrai-homepage__hero-bg">
        {%- if all_collection.products.first.featured_image != blank -%}
          {{ all_collection.products.first.featured_image | image_url: width: 2000 | image_tag: alt: 'New season arrivals', loading: 'eager' }}
        {%- elsif all_collection.image != blank -%}
          {{ all_collection.image | image_url: width: 2000 | image_tag: alt: 'Shop the collection', loading: 'eager' }}
        {%- else -%}
          <img src="https://images.unsplash.com/photo-1496747611176-843222e1e57c?auto=format&fit=crop&w=2000&q=80" alt="Editorial fashion" loading="eager">
        {%- endif -%}
        <div class="vrai-homepage__hero-gradient"></div>
      </div>
      <div class="vrai-homepage__hero-copy vrai-homepage__hero-copy--bottom">
        <h1 id="VraiHomepageHeroTitle">AN EDITORIAL STOREFRONT FOR MODERN DRESSING.</h1>
        <div class="vrai-homepage__hero-actions">
          <a class="vrai-homepage__button vrai-homepage__button--primary" href="{{ routes.all_products_collection_url }}">Shop the collection</a>
          <a class="vrai-homepage__button vrai-homepage__button--ghost vrai-homepage__button--ghost-light" href="{{ minimal_url }}">Read edits</a>
        </div>
      </div>
    </section>

    <section class="vrai-homepage__collections vrai-reveal" aria-labelledby="VraiHomepageCollectionsTitle">
      <div class="vrai-homepage__section-heading vrai-homepage__section-heading--split">
        <h2 id="VraiHomepageCollectionsTitle">Shop by Mood</h2>
        <span class="vrai-homepage__eyebrow">Curated Atmospheres</span>
      </div>
      <div class="vrai-homepage__collection-grid vrai-homepage__collection-grid--asymmetric">
        {%- for handle in mood_handles -%}
          {%- assign mood_collection = collections[handle] -%}
          {%- assign mood_title = mood_collection.title -%}
          {%- if mood_collection == blank -%}
            {%- continue -%}
          {%- endif -%}
          <a class="vrai-homepage__collection-card vrai-homepage__collection-card--overlay" href="{{ mood_collection.url }}">
            {%- if mood_collection.image != blank -%}
              {{ mood_collection.image | image_url: width: 1200 | image_tag: alt: mood_title, loading: 'lazy' }}
            {%- elsif mood_collection.products.first.images[1] != blank -%}
              {{ mood_collection.products.first.images[1] | image_url: width: 1200 | image_tag: alt: mood_title, loading: 'lazy' }}
            {%- elsif mood_collection.products.first.featured_image != blank -%}
              {{ mood_collection.products.first.featured_image | image_url: width: 1200 | image_tag: alt: mood_title, loading: 'lazy' }}
            {%- else -%}
              <img src="https://images.unsplash.com/photo-1529139574466-a303027c1d8b?auto=format&fit=crop&w=1200&q=80" alt="{{ mood_title | escape }}" loading="lazy">
            {%- endif -%}
            <span class="vrai-homepage__collection-overlay"></span>
            <strong>{{ mood_title }}</strong>
          </a>
        {%- endfor -%}
      </div>
    </section>

    <section class="vrai-homepage__products vrai-reveal" aria-labelledby="VraiHomepageProductsTitle">
      <div class="vrai-homepage__section-heading vrai-homepage__section-heading--split">
        <div>
          <p class="vrai-homepage__eyebrow">The Archive</p>
          <h2 id="VraiHomepageProductsTitle">Fresh Arrivals</h2>
        </div>
        <div class="vrai-homepage__carousel-nav">
          <button class="vrai-homepage__carousel-btn" data-dir="prev" aria-label="Previous products">
            <span class="material-symbols-outlined">arrow_back</span>
          </button>
          <button class="vrai-homepage__carousel-btn" data-dir="next" aria-label="Next products">
            <span class="material-symbols-outlined">arrow_forward</span>
          </button>
        </div>
      </div>

      <div class="vrai-homepage__product-carousel" data-vrai-carousel>
        {%- if all_collection != blank and all_collection.products_count > 0 -%}
          {%- for product in all_collection.products limit: 8 -%}
            {%- assign first_variant = product.selected_or_first_available_variant -%}
            <article class="vrai-homepage__carousel-card">
              <a class="vrai-homepage__carousel-image" href="{{ product.url }}">
                {%- if product.featured_image != blank -%}
                  {{ product.featured_image | image_url: width: 900 | image_tag: alt: product.title, loading: 'lazy' }}
                {%- else -%}
                  <img src="https://images.unsplash.com/photo-1434389677669-e08b4cda3a76?auto=format&fit=crop&w=900&q=80" alt="{{ product.title | escape }}" loading="lazy">
                {%- endif -%}
              </a>
              <div class="vrai-homepage__carousel-meta">
                <h4><a href="{{ product.url }}">{{ product.title | truncatewords: 6, '' }}</a></h4>
                <span class="vrai-homepage__carousel-price">{{ product.price | money }}</span>
              </div>
            </article>
          {%- endfor -%}
        {%- else -%}
          <article class="vrai-homepage__carousel-card">
            <div class="vrai-homepage__carousel-image"><img src="https://images.unsplash.com/photo-1594938298603-c8148c4dae35?auto=format&fit=crop&w=900&q=80" alt="Oversized linen blazer" loading="lazy"></div>
            <div class="vrai-homepage__carousel-meta"><h4>Oversized Linen Blazer</h4><span class="vrai-homepage__carousel-price">$285</span></div>
          </article>
          <article class="vrai-homepage__carousel-card">
            <div class="vrai-homepage__carousel-image"><img src="https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?auto=format&fit=crop&w=900&q=80" alt="Silk midi dress" loading="lazy"></div>
            <div class="vrai-homepage__carousel-meta"><h4>Silk Midi Dress</h4><span class="vrai-homepage__carousel-price">$345</span></div>
          </article>
          <article class="vrai-homepage__carousel-card">
            <div class="vrai-homepage__carousel-image"><img src="https://images.unsplash.com/photo-1591047139829-d91aecb6caea?auto=format&fit=crop&w=900&q=80" alt="Tailored wool coat" loading="lazy"></div>
            <div class="vrai-homepage__carousel-meta"><h4>Tailored Wool Coat</h4><span class="vrai-homepage__carousel-price">$420</span></div>
          </article>
        {%- endif -%}
      </div>
    </section>

    <section class="vrai-homepage__brand-story vrai-reveal" aria-labelledby="VraiBrandStoryTitle">
      <div class="vrai-homepage__brand-story-content">
        <div class="vrai-homepage__brand-story-media">
          {%- assign available_story_products = all_collection.products | where: 'available', true -%}
          {%- assign story_product = available_story_products.first -%}
          {%- if story_product.images[2] != blank -%}
            {{ story_product.images[2] | image_url: width: 1800 | image_tag: alt: 'Our Story', loading: 'lazy', class: 'vrai-homepage__brand-story-img' }}
          {%- elsif story_product.featured_image != blank -%}
            {{ story_product.featured_image | image_url: width: 1800 | image_tag: alt: 'Our Story', loading: 'lazy', class: 'vrai-homepage__brand-story-img' }}
          {%- else -%}
            <img src="https://images.unsplash.com/photo-1469334031218-e382a71b716b?auto=format&fit=crop&w=1800&q=80" alt="Brand story visual" loading="lazy" class="vrai-homepage__brand-story-img">
          {%- endif -%}
          <div class="vrai-homepage__brand-story-quote">
            <p>&ldquo;Style is the signature of our existence in the world of forms.&rdquo;</p>
          </div>
        </div>
        <div class="vrai-homepage__brand-story-text">
          <h2 id="VraiBrandStoryTitle">REDEFINING AUTHENTIC STYLE.</h2>
          <div class="vrai-homepage__brand-story-body">
            <p>At VRAI, we believe clothing should be an extension of the soul. Our curation process favors the enduring over the ephemeral, the textured over the flat, and the authentic over the artificial.</p>
          </div>
          <a class="vrai-homepage__text-link--underline" href="/pages/about">Discover our philosophy</a>
        </div>
      </div>
    </section>

    <section class="vrai-homepage__ugc vrai-reveal" aria-labelledby="VraiHomepageUgcTitle">
      <div class="vrai-homepage__section-heading vrai-homepage__section-heading--center">
        <p class="vrai-homepage__eyebrow">The Community</p>
        <h2 id="VraiHomepageUgcTitle">Vrai Canada</h2>
        <p class="vrai-homepage__ugc-sub">Tag us #VraiArchive to be featured in our monthly spread.</p>
      </div>
      <div class="vrai-homepage__ugc-grid vrai-homepage__ugc-grid--4col">
        {%- for product in all_collection.products limit: 4 -%}
          <a href="{{ product.url }}" class="vrai-homepage__ugc-item" aria-label="View {{ product.title | escape }}">
            {%- if product.images[1] != blank -%}
              {{ product.images[1] | image_url: width: 700 | image_tag: alt: product.title, loading: 'lazy' }}
            {%- elsif product.featured_image != blank -%}
              {{ product.featured_image | image_url: width: 700 | image_tag: alt: product.title, loading: 'lazy' }}
            {%- else -%}
              <img src="https://images.unsplash.com/photo-1529139574466-a303027c1d8b?auto=format&fit=crop&w=700&q=80" alt="Community style" loading="lazy">
            {%- endif -%}
            <div class="vrai-homepage__ugc-overlay">
              <span class="material-symbols-outlined">favorite</span>
            </div>
          </a>
        {%- endfor -%}
      </div>
    </section>

    <section class="vrai-homepage__newsletter vrai-reveal" aria-labelledby="VraiHomepageNewsletterTitle">
      <div>
        <p class="vrai-homepage__eyebrow">Private list</p>
        <h2 id="VraiHomepageNewsletterTitle">Get 10% off your first order.</h2>
        <p class="vrai-homepage__newsletter-sub">Join for early access to new drops, capsule releases, and member-only offers.</p>
      </div>
      {%- form 'customer', class: 'vrai-homepage__newsletter-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <label class="visually-hidden" for="VraiHomepageEmail">Email address</label>
        <input id="VraiHomepageEmail" type="email" name="contact[email]" placeholder="Email address" required>
        <button type="submit">Join now</button>
        <p class="vrai-homepage__privacy-note">By joining, you agree to receive marketing emails. You can unsubscribe at any time.</p>
      {%- endform -%}
    </section>
  </main>
</section>

{% schema %}
{
  "name": "Homepage redesign",
  "settings": [],
  "presets": [
    {
      "name": "Homepage redesign"
    }
  ]
}
{% endschema %}