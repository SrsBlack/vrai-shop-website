{{ 'homepage-redesign.css' | asset_url | stylesheet_tag }}
<script src="{{ 'store-redesign.js' | asset_url }}" defer></script>

{%- liquid
  assign all_collection = collections['all']
  assign all_collections_url = routes.collections_url
  if all_collections_url == blank
    assign all_collections_url = '/collections'
  endif
  assign adventure_collection = collections['adventure-series']
  assign streetwear_collection = collections['streetwear']
  assign minimal_collection = collections['minimal']
  assign coquette_collection = collections['trending-now-coquette']
  assign mood_handles = 'adventure-series,minimal,streetwear,trending-now-coquette' | split: ','
  assign now_timestamp = 'now' | date: '%s' | plus: 0
  assign fourteen_days_seconds = 1209600
  assign new_threshold = now_timestamp | minus: fourteen_days_seconds

  assign adventure_url = routes.all_products_collection_url
  if adventure_collection != blank
    assign adventure_url = adventure_collection.url
  endif

  assign streetwear_url = routes.all_products_collection_url
  if streetwear_collection != blank
    assign streetwear_url = streetwear_collection.url
  endif

  assign minimal_url = routes.all_products_collection_url
  if minimal_collection != blank
    assign minimal_url = minimal_collection.url
  endif
-%}

<section class="vrai-homepage">
  <a href="#VraiHomepageMain" class="vrai-homepage__skip-link">Skip to content</a>

  <main id="VraiHomepageMain" class="vrai-homepage__main">
    <section class="vrai-homepage__hero vrai-reveal" aria-labelledby="VraiHomepageHeroTitle">
      <div class="vrai-homepage__hero-copy">
        <p class="vrai-homepage__eyebrow">Spring / Summer 2026</p>
        <h1 id="VraiHomepageHeroTitle">AN EDITORIAL STOREFRONT FOR MODERN DRESSING.</h1>
        <p class="vrai-homepage__lede">
          Structured tailoring, fluid essentials, and elevated layers curated with a quieter luxury point of view.
        </p>
        <div class="vrai-homepage__hero-actions">
          <a class="vrai-homepage__button vrai-homepage__button--primary" href="{{ routes.all_products_collection_url }}">Shop the edit</a>
          <a class="vrai-homepage__button vrai-homepage__button--ghost" href="{{ minimal_url }}">View minimal</a>
        </div>
      </div>
      <div class="vrai-homepage__hero-media" data-vrai-parallax-wrap>
        {%- if all_collection.products.first.featured_image != blank -%}
          {{ all_collection.products.first.featured_image | image_url: width: 1400 | image_tag: alt: 'New season arrivals', loading: 'eager', class: 'vrai-homepage__parallax-image' }}
        {%- elsif all_collection.image != blank -%}
          {{ all_collection.image | image_url: width: 1400 | image_tag: alt: 'Shop the collection', loading: 'eager', class: 'vrai-homepage__parallax-image' }}
        {%- else -%}
          <img src="https://images.unsplash.com/photo-1496747611176-843222e1e57c?auto=format&fit=crop&w=1400&q=80" alt="Model wearing a tailored neutral look in studio lighting" loading="eager" class="vrai-homepage__parallax-image">
        {%- endif -%}
      </div>
    </section>

    <section class="vrai-homepage__collections vrai-reveal" aria-labelledby="VraiHomepageCollectionsTitle">
      <div class="vrai-homepage__section-heading">
        <p class="vrai-homepage__eyebrow">Collections</p>
        <h2 id="VraiHomepageCollectionsTitle">Shop by mood</h2>
      </div>
      <div class="vrai-homepage__collection-grid">
        {%- for handle in mood_handles -%}
          {%- assign mood_collection = collections[handle] -%}
          {%- assign mood_title = mood_collection.title -%}
          {%- if mood_collection == blank -%}
            {%- continue -%}
          {%- endif -%}
          <a class="vrai-homepage__collection-card vrai-homepage__collection-card--overlay" href="{{ mood_collection.url }}">
            {%- if mood_collection.image != blank -%}
              {{ mood_collection.image | image_url: width: 1200 | image_tag: alt: mood_title, loading: 'lazy' }}
            {%- elsif mood_collection.products.first.images[1] != blank -%}
              {{ mood_collection.products.first.images[1] | image_url: width: 1200 | image_tag: alt: mood_title, loading: 'lazy' }}
            {%- elsif mood_collection.products.first.featured_image != blank -%}
              {{ mood_collection.products.first.featured_image | image_url: width: 1200 | image_tag: alt: mood_title, loading: 'lazy' }}
            {%- else -%}
              <img src="https://images.unsplash.com/photo-1529139574466-a303027c1d8b?auto=format&fit=crop&w=1200&q=80" alt="{{ mood_title | escape }}" loading="lazy">
            {%- endif -%}
            <span class="vrai-homepage__collection-overlay"></span>
            <strong>{{ mood_title }}</strong>
          </a>
        {%- endfor -%}
      </div>
    </section>

    <section class="vrai-homepage__products vrai-reveal" aria-labelledby="VraiHomepageProductsTitle">
      <div class="vrai-homepage__section-heading vrai-homepage__section-heading--split">
        <div>
          <p class="vrai-homepage__eyebrow">Now available</p>
          <h2 id="VraiHomepageProductsTitle">Fresh arrivals</h2>
        </div>
        <a class="vrai-homepage__text-link" href="{{ routes.all_products_collection_url }}">View all</a>
      </div>

      <div class="vrai-homepage__product-grid">
        {%- if all_collection != blank and all_collection.products_count > 0 -%}
          {%- for product in all_collection.products limit: 4 -%}
            {%- assign first_variant = product.selected_or_first_available_variant -%}
            {%- assign product_created_timestamp = product.created_at | date: '%s' | plus: 0 -%}
            <article class="vrai-homepage__product-card">
              <a class="vrai-homepage__product-image" href="{{ product.url }}">
                {%- if product_created_timestamp > new_threshold -%}
                  <span class="vrai-card__badge vrai-card__badge--new">New</span>
                {%- endif -%}
                {%- if product.featured_image != blank -%}
                  {{ product.featured_image | image_url: width: 900 | image_tag: alt: product.title, loading: 'lazy', class: 'vrai-homepage__image-primary' }}
                  {%- if product.images[1] != blank -%}
                    {{ product.images[1] | image_url: width: 900 | image_tag: alt: product.title, loading: 'lazy', class: 'vrai-homepage__image-secondary' }}
                  {%- endif -%}
                {%- else -%}
                  <img src="https://images.unsplash.com/photo-1434389677669-e08b4cda3a76?auto=format&fit=crop&w=900&q=80" alt="{{ product.title | escape }}" loading="lazy" class="vrai-homepage__image-primary">
                {%- endif -%}
              </a>
              <div class="vrai-homepage__product-body">
                <h3><a href="{{ product.url }}">{{ product.title | truncatewords: 6, '' }}</a></h3>
                <p class="vrai-homepage__product-price">
                  {{ product.price | money }}
                  {%- if product.compare_at_price > product.price -%}
                    <span>{{ product.compare_at_price | money }}</span>
                  {%- endif -%}
                </p>
                {%- if first_variant != blank and first_variant.available -%}
                  {%- form 'product', product, class: 'vrai-homepage__quick-add-form' -%}
                    <input type="hidden" name="id" value="{{ first_variant.id }}">
                    <button type="submit" class="vrai-homepage__quick-add">Quick add</button>
                  {%- endform -%}
                {%- endif -%}
              </div>
            </article>
          {%- endfor -%}
        {%- else -%}
          <article class="vrai-homepage__product-card">
            <div class="vrai-homepage__product-image"><img src="https://images.unsplash.com/photo-1594938298603-c8148c4dae35?auto=format&fit=crop&w=900&q=80" alt="Oversized linen blazer" loading="lazy"></div>
            <div class="vrai-homepage__product-body"><p class="vrai-homepage__product-vendor">VRAI</p><h3>Oversized Linen Blazer</h3><p class="vrai-homepage__product-price">$285</p></div>
          </article>
          <article class="vrai-homepage__product-card">
            <div class="vrai-homepage__product-image"><img src="https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?auto=format&fit=crop&w=900&q=80" alt="Silk midi dress" loading="lazy"></div>
            <div class="vrai-homepage__product-body"><p class="vrai-homepage__product-vendor">VRAI</p><h3>Silk Midi Dress</h3><p class="vrai-homepage__product-price">$345</p></div>
          </article>
          <article class="vrai-homepage__product-card">
            <div class="vrai-homepage__product-image"><img src="https://images.unsplash.com/photo-1591047139829-d91aecb6caea?auto=format&fit=crop&w=900&q=80" alt="Tailored wool coat" loading="lazy"></div>
            <div class="vrai-homepage__product-body"><p class="vrai-homepage__product-vendor">VRAI</p><h3>Tailored Wool Coat</h3><p class="vrai-homepage__product-price">$420 <span>$560</span></p></div>
          </article>
          <article class="vrai-homepage__product-card">
            <div class="vrai-homepage__product-image"><img src="https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?auto=format&fit=crop&w=900&q=80" alt="Cashmere knit" loading="lazy"></div>
            <div class="vrai-homepage__product-body"><p class="vrai-homepage__product-vendor">VRAI</p><h3>Cashmere Knit</h3><p class="vrai-homepage__product-price">$190</p></div>
          </article>
        {%- endif -%}
      </div>
    </section>

    <section class="vrai-homepage__brand-story vrai-reveal" aria-labelledby="VraiBrandStoryTitle">
      <div class="vrai-homepage__brand-story-content">
        <div class="vrai-homepage__brand-story-media">
          {%- assign available_story_products = all_collection.products | where: 'available', true -%}
          {%- assign story_product = available_story_products.first -%}
          {%- if story_product.images[2] != blank -%}
            {{ story_product.images[2] | image_url: width: 1800 | image_tag: alt: 'Our Story', loading: 'lazy', class: 'vrai-homepage__brand-story-img' }}
          {%- elsif story_product.featured_image != blank -%}
            {{ story_product.featured_image | image_url: width: 1800 | image_tag: alt: 'Our Story', loading: 'lazy', class: 'vrai-homepage__brand-story-img' }}
          {%- else -%}
            <img src="https://images.unsplash.com/photo-1469334031218-e382a71b716b?auto=format&fit=crop&w=1800&q=80" alt="Brand story visual" loading="lazy" class="vrai-homepage__brand-story-img">
          {%- endif -%}
        </div>
        <div class="vrai-homepage__brand-story-text">
          <p class="vrai-homepage__eyebrow">Our story</p>
          <h2 id="VraiBrandStoryTitle">Redefining authentic style</h2>
          <div class="vrai-homepage__brand-story-body">
            <p>VRAI was born from a belief that authentic style doesn't follow trends - it creates them. We curate for the modern individual: quality over quantity, timelessness over seasonality.</p>
            <p>Since 2024, every piece is thoughtfully selected from artisans who share our commitment to craft.</p>
          </div>
          <a class="vrai-homepage__button vrai-homepage__button--primary" href="/pages/about">Discover our story</a>
        </div>
      </div>
    </section>

    <section class="vrai-homepage__ugc vrai-reveal" aria-labelledby="VraiHomepageUgcTitle">
      <div class="vrai-homepage__section-heading">
        <p class="vrai-homepage__eyebrow">Community</p>
        <h2 id="VraiHomepageUgcTitle">#VRAICANADA</h2>
      </div>
      <div class="vrai-homepage__ugc-grid">
        {%- for product in all_collection.products limit: 6 -%}
          <a href="{{ product.url }}" class="vrai-homepage__ugc-item" aria-label="View {{ product.title | escape }}">
            {%- if product.images[1] != blank -%}
              {{ product.images[1] | image_url: width: 700 | image_tag: alt: product.title, loading: 'lazy' }}
            {%- elsif product.featured_image != blank -%}
              {{ product.featured_image | image_url: width: 700 | image_tag: alt: product.title, loading: 'lazy' }}
            {%- else -%}
              <img src="https://images.unsplash.com/photo-1529139574466-a303027c1d8b?auto=format&fit=crop&w=700&q=80" alt="Community style" loading="lazy">
            {%- endif -%}
          </a>
        {%- endfor -%}
      </div>
    </section>

    <section class="vrai-homepage__newsletter vrai-reveal" aria-labelledby="VraiHomepageNewsletterTitle">
      <div>
        <p class="vrai-homepage__eyebrow">Private list</p>
        <h2 id="VraiHomepageNewsletterTitle">Get 10% off your first order.</h2>
        <p class="vrai-homepage__newsletter-sub">Join for early access to new drops, capsule releases, and member-only offers.</p>
      </div>
      {%- form 'customer', class: 'vrai-homepage__newsletter-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <label class="visually-hidden" for="VraiHomepageEmail">Email address</label>
        <input id="VraiHomepageEmail" type="email" name="contact[email]" placeholder="Email address" required>
        <button type="submit">Join now</button>
        <p class="vrai-homepage__privacy-note">By joining, you agree to receive marketing emails. You can unsubscribe at any time.</p>
        {%- if form.posted_successfully? -%}
          <p class="vrai-homepage__form-message" role="status">You are on the list.</p>
        {%- endif -%}
        {%- if form.errors -%}
          <p class="vrai-homepage__form-message vrai-homepage__form-message--error" role="alert">{{ form.errors | default_errors }}</p>
        {%- endif -%}
      {%- endform -%}
    </section>
  </main>
</section>

{% schema %}
{
  "name": "Homepage redesign",
  "settings": [],
  "blocks": [],
  "presets": [
    {
      "name": "Homepage redesign"
    }
  ]
}
{% endschema %}