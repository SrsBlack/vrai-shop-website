{{ 'store-redesign.css' | asset_url | stylesheet_tag }}
<script src="{{ 'store-redesign.js' | asset_url }}" defer></script>

<section class="vrai-store-page vrai-about-page">
  <nav class="vrai-breadcrumbs" aria-label="Breadcrumb">
    <a href="{{ routes.root_url }}">Home</a>
    <span class="vrai-breadcrumbs__separator">/</span>
    <span aria-current="page">About</span>
  </nav>

  <section class="vrai-about__hero vrai-reveal" aria-labelledby="VraiAboutHeroTitle">
    <div class="vrai-about__hero-media">
      {%- if section.settings.hero_image != blank -%}
        {{ section.settings.hero_image | image_url: width: 2200 | image_tag: alt: 'VRAI brand story', loading: 'eager' }}
      {%- else -%}
        <img src="https://images.unsplash.com/photo-1469334031218-e382a71b716b?auto=format&fit=crop&w=2200&q=80" alt="VRAI brand story" loading="eager">
      {%- endif -%}
      <h1 id="VraiAboutHeroTitle">Our Story</h1>
    </div>
  </section>

  <section class="vrai-about__narrative vrai-reveal">
    <p>VRAI was born from a belief that authentic style does not follow trends - it creates them. We curate for the modern individual: quality over quantity, timelessness over seasonality.</p>
    <p>Since 2024, each piece has been selected with intention from artisans and independent labels that prioritize craft, fit, and longevity. We are anti-hype by design, and fashion-first in every decision.</p>
    <p>Our mission is simple: build a quieter, sharper way to shop fashion online - one that feels editorial, personal, and true.</p>
  </section>

  <section class="vrai-about__values vrai-reveal" aria-label="Our values">
    <article>
      <h2>Quality</h2>
      <p>Premium fabrics, precise silhouettes, and lasting construction.</p>
    </article>
    <article>
      <h2>Craft</h2>
      <p>Thoughtful sourcing from makers who value process and detail.</p>
    </article>
    <article>
      <h2>Authenticity</h2>
      <p>Original style choices grounded in confidence, not noise.</p>
    </article>
  </section>

  <section class="vrai-about__founder vrai-reveal">
    <h2>A note from the founder</h2>
    <p>VRAI is a long-term project in taste, trust, and authenticity. Every collection is curated to help you build a wardrobe that feels like you - not like everyone else.</p>
    <a class="vrai-cta" href="{{ routes.all_products_collection_url }}">Shop the edit</a>
  </section>
</section>

{% schema %}
{
  "name": "About redesign",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    }
  ],
  "presets": [
    {
      "name": "About redesign"
    }
  ]
}
{% endschema %}
