{{ 'store-redesign.css' | asset_url | stylesheet_tag }}
<script src="{{ 'store-redesign.js' | asset_url }}" defer></script>

<section class="vrai-store-page vrai-article-page">
  <nav class="vrai-breadcrumbs" aria-label="Breadcrumb">
    <a href="{{ routes.root_url }}">Home</a>
    <span class="vrai-breadcrumbs__separator">/</span>
    <a href="{{ blog.url }}">Journal</a>
    <span class="vrai-breadcrumbs__separator">/</span>
    <span aria-current="page">{{ article.title | truncate: 40 }}</span>
  </nav>

  <header class="vrai-product__top vrai-reveal">
    <p class="vrai-store-page__eyebrow">Editorial</p>
    <h1 class="vrai-store-page__title">{{ article.title }}</h1>
    <p class="vrai-article__meta">{{ article.published_at | date: '%B %d, %Y' }}{% if article.author != blank %} / {{ article.author }}{% endif %}</p>
  </header>

  <article class="vrai-article">
    <div class="vrai-article__body">
      {% if article.image %}
        {{ article.image | image_url: width: 1600 | image_tag: alt: article.title, class: 'vrai-article__hero', loading: 'eager' }}
      {% endif %}

      <div class="vrai-article__content rte">{{ article.content }}</div>

      <p class="vrai-article__back">
        <a class="vrai-ghost-cta" href="{{ blog.url }}">Back to {{ blog.title }}</a>
      </p>
    </div>
  </article>
</section>

{% schema %}
{
  "name": "Article redesign",
  "settings": [],
  "presets": [
    {
      "name": "Article redesign"
    }
  ]
}
{% endschema %}
