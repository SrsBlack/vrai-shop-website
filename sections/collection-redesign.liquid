{{ 'store-redesign.css' | asset_url | stylesheet_tag }}
<script src="{{ 'store-redesign.js' | asset_url }}" defer></script>

{%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}

<section class="vrai-store-page vrai-collection">
  <nav class="vrai-breadcrumbs" aria-label="Breadcrumb">
    <a href="{{ routes.root_url }}">Home</a>
    <span class="vrai-breadcrumbs__separator">/</span>
    <span aria-current="page">{{ collection.title }}</span>
  </nav>

  <header class="vrai-collection__head vrai-reveal">
    <p class="vrai-store-page__eyebrow">Collection</p>
    <h1 class="vrai-store-page__title">{{ collection.title }}</h1>
    {%- if collection.image != blank -%}
      <div class="vrai-collection__hero-media">
        {{ collection.image | image_url: width: 2200 | image_tag: alt: collection.title, loading: 'eager' }}
      </div>
    {%- endif -%}
    {%- if collection.description != blank -%}
      <div class="vrai-store-page__lead">{{ collection.description }}</div>
    {%- else -%}
      <p class="vrai-store-page__lead">A curated edit of {{ collection.title | downcase }} built for modern dressing and intentional wardrobes.</p>
    {%- endif -%}
  </header>

  <div class="vrai-collection__toolbar">
    <p class="vrai-collection__count">{{ collection.products_count }} products</p>
    <form method="get" class="vrai-collection__sort">
      <label for="SortBy">Sort</label>
      <select id="SortBy" name="sort_by" onchange="this.form.submit()">
        {%- for option in collection.sort_options -%}
          <option value="{{ option.value }}" {% if option.value == sort_by %}selected{% endif %}>{{ option.name }}</option>
        {%- endfor -%}
      </select>
    </form>
  </div>

  {%- paginate collection.products by 12 -%}
    {%- if collection.products_count > 0 -%}
      {%- comment -%} Calculate 14 days ago timestamp for "New" badge {%- endcomment -%}
      {%- assign now_timestamp = 'now' | date: '%s' | plus: 0 -%}
      {%- assign fourteen_days_seconds = 1209600 -%}
      {%- assign new_threshold = now_timestamp | minus: fourteen_days_seconds -%}

      <div class="vrai-collection__layout">
        <aside class="vrai-collection__sidebar" aria-label="Product filters">
          {%- if collection.filters.size > 0 -%}
            <form class="vrai-collection__filter-form" id="VraiCollectionFilters" method="get">
              {%- if sort_by != blank -%}
                <input type="hidden" name="sort_by" value="{{ sort_by | escape }}">
              {%- endif -%}
              {%- for filter in collection.filters -%}
                <details class="vrai-filter-group" {% if forloop.first %}open{% endif %}>
                  <summary>{{ filter.label }}</summary>
                  <div class="vrai-filter-group__content">
                    {%- case filter.type -%}
                      {%- when 'boolean' or 'list' -%}
                        {%- for value in filter.values -%}
                          <label class="vrai-filter-option" for="Filter-{{ filter.label | escape }}-{{ forloop.index }}">
                            <input
                              id="Filter-{{ filter.label | escape }}-{{ forloop.index }}"
                              type="checkbox"
                              name="{{ value.param_name }}"
                              value="{{ value.value }}"
                              {% if value.active %}checked{% endif %}
                              {% if value.count == 0 and value.active == false %}disabled{% endif %}
                            >
                            <span>{{ value.label }} ({{ value.count }})</span>
                          </label>
                        {%- endfor -%}
                      {%- when 'price_range' -%}
                        <div class="vrai-filter-price">
                          <label for="Filter-{{ filter.min_value.param_name }}">From</label>
                          <input
                            id="Filter-{{ filter.min_value.param_name }}"
                            name="{{ filter.min_value.param_name }}"
                            type="number"
                            min="0"
                            max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                            value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"
                            placeholder="0"
                          >
                          <label for="Filter-{{ filter.max_value.param_name }}">To</label>
                          <input
                            id="Filter-{{ filter.max_value.param_name }}"
                            name="{{ filter.max_value.param_name }}"
                            type="number"
                            min="0"
                            max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                            value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"
                            placeholder="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                          >
                        </div>
                    {%- endcase -%}
                  </div>
                </details>
              {%- endfor -%}
              <button type="submit" class="vrai-filter-submit">Apply filters</button>
            </form>
          {%- endif -%}
        </aside>

        <div class="vrai-collection__grid">
          {%- for product in collection.products -%}
          {%- assign first_variant = product.selected_or_first_available_variant -%}
          <article class="vrai-card vrai-reveal">
            <button type="button" class="vrai-card__wishlist" aria-label="Add {{ product.title | escape }} to wishlist">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
            </button>
            <a class="vrai-card__image" href="{{ product.url }}">
              {%- assign product_created_timestamp = product.created_at | date: '%s' | plus: 0 -%}
              {%- if product.compare_at_price > product.price -%}
                {%- assign save_pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
                <span class="vrai-card__badge vrai-card__badge--sale">Save {{ save_pct }}%</span>
              {%- elsif product_created_timestamp > new_threshold -%}
                <span class="vrai-card__badge vrai-card__badge--new">New</span>
              {%- endif -%}
              {%- if product.featured_image != blank -%}
                {{ product.featured_image | image_url: width: 900 | image_tag: alt: product.title, loading: 'lazy', class: 'vrai-card__image-primary' }}
                {%- if product.images[1] != blank -%}
                  {{ product.images[1] | image_url: width: 900 | image_tag: alt: product.title, loading: 'lazy', class: 'vrai-card__image-secondary' }}
                {%- endif -%}
              {%- endif -%}
            </a>
            <button 
              class="vrai-card__quickview" 
              type="button" 
              data-vrai-quickview
              data-product-id="{{ product.id }}"
              data-product-url="{{ product.url }}"
              data-product-title="{{ product.title | escape }}"
              data-product-vendor="{{ product.vendor | escape }}"
              data-product-price="{{ first_variant.price | money | escape }}"
              data-product-image="{{ product.featured_image | image_url: width: 600 }}"
              data-product-available="{{ first_variant.available }}"
              aria-label="Quick view {{ product.title | escape }}"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
              Quick View
            </button>
            <div class="vrai-card__body">
              <h2 class="vrai-card__title"><a href="{{ product.url }}">{{ product.title | truncatewords: 6, '' }}</a></h2>
              <p class="vrai-card__price">
                {{ product.price | money }}
                {%- if product.compare_at_price > product.price -%}
                  <span class="vrai-card__compare">{{ product.compare_at_price | money }}</span>
                {%- endif -%}
              </p>
            </div>
          </article>
          {%- endfor -%}
        </div>
      </div>
    {%- else -%}
      <div class="vrai-empty-state">
        <p>No products found in this collection yet.</p>
      </div>
    {%- endif -%}

    {%- if paginate.pages > 1 -%}
      <nav class="vrai-pagination" aria-label="Pagination">
        {%- if paginate.previous -%}
          <a href="{{ paginate.previous.url }}">Prev</a>
        {%- endif -%}

        {%- for part in paginate.parts -%}
          {%- if part.is_link -%}
            <a href="{{ part.url }}">{{ part.title }}</a>
          {%- elsif part.title == paginate.current_page -%}
            <span class="current" aria-current="page">{{ part.title }}</span>
          {%- else -%}
            <span>{{ part.title }}</span>
          {%- endif -%}
        {%- endfor -%}

        {%- if paginate.next -%}
          <a href="{{ paginate.next.url }}">Next</a>
        {%- endif -%}
      </nav>
    {%- endif -%}
  {%- endpaginate -%}

  <div class="vrai-quickview-modal" data-vrai-quickview-modal hidden role="dialog" aria-modal="true" aria-label="Quick product view">
    <div class="vrai-quickview__content">
      <button type="button" class="vrai-quickview__close" data-vrai-quickview-close aria-label="Close quick view">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
      <div class="vrai-quickview__body">
        <div class="vrai-quickview__image-wrapper">
          <img src="" alt="" data-vrai-quickview-image class="vrai-quickview__image">
        </div>
        <div class="vrai-quickview__info">
          <p class="vrai-quickview__vendor" data-vrai-quickview-vendor></p>
          <h2 class="vrai-quickview__title" data-vrai-quickview-title></h2>
          <p class="vrai-quickview__price" data-vrai-quickview-price></p>
          <p class="vrai-quickview__availability" data-vrai-quickview-availability></p>
          <div class="vrai-quickview__actions">
            <a href="#" class="vrai-quickview__btn vrai-quickview__btn--primary" data-vrai-quickview-link>View Full Details</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection redesign",
  "settings": [],
  "presets": [
    {
      "name": "Collection redesign"
    }
  ]
}
{% endschema %}
