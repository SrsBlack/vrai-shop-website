{{ 'store-redesign.css' | asset_url | stylesheet_tag }}
<script src="{{ 'store-redesign.js' | asset_url }}" defer></script>

<section class="vrai-store-page vrai-blog-page">
  <nav class="vrai-breadcrumbs" aria-label="Breadcrumb">
    <a href="{{ routes.root_url }}">Home</a>
    <span class="vrai-breadcrumbs__separator">/</span>
    <span aria-current="page">Journal</span>
  </nav>

  <header class="vrai-product__top vrai-reveal">
    <p class="vrai-store-page__eyebrow">The Archive</p>
    <h1 class="vrai-store-page__title">Journal</h1>
    <p class="vrai-store-page__lead">Editorial notes, style stories, and behind-the-label updates.</p>
  </header>

  <div class="vrai-blog">
    {% paginate blog.articles by 9 %}
      {% if blog.articles_count > 0 %}
        {%- assign featured = blog.articles | first -%}
        <article class="vrai-blog__featured">
          <a href="{{ featured.url }}" class="vrai-blog__featured-image">
            {% if featured.image %}
              {{ featured.image | image_url: width: 1400 | image_tag: alt: featured.title, loading: 'eager' }}
            {% else %}
              {{ 'collection-1' | placeholder_svg_tag }}
            {% endif %}
          </a>
          <div class="vrai-blog__featured-content">
            <p class="vrai-blog__meta">{{ featured.published_at | date: '%B %d, %Y' }} &mdash; {{ featured.tags | first }}</p>
            <h2 class="vrai-blog__featured-title"><a href="{{ featured.url }}">{{ featured.title }}</a></h2>
            <p class="vrai-blog__excerpt">{{ featured.excerpt_or_content | strip_html | truncate: 200 }}</p>
            <a class="vrai-homepage__text-link--underline" href="{{ featured.url }}">Read story</a>
          </div>
        </article>

        <div class="vrai-blog__grid">
          {% for article in blog.articles offset: 1 %}
            <article class="vrai-blog__card">
              <a href="{{ article.url }}" class="vrai-blog__card-image">
                {% if article.image %}
                  {{ article.image | image_url: width: 980 | image_tag: alt: article.title, loading: 'lazy' }}
                {% else %}
                  {{ 'collection-1' | placeholder_svg_tag }}
                {% endif %}
              </a>
              <div class="vrai-blog__card-content">
                <p class="vrai-blog__meta">{{ article.published_at | date: '%B %d, %Y' }}</p>
                <h2 class="vrai-blog__title"><a href="{{ article.url }}">{{ article.title }}</a></h2>
                <p class="vrai-blog__excerpt">{{ article.excerpt_or_content | strip_html | truncate: 130 }}</p>
                <a class="vrai-homepage__text-link--underline" href="{{ article.url }}">Read story</a>
              </div>
            </article>
          {% endfor %}
        </div>
      {% else %}
        <div class="vrai-empty-state">
          <span class="material-symbols-outlined vrai-empty-state__icon" aria-hidden="true">edit_note</span>
          <p>No stories yet. Check back soon for our next editorial drop.</p>
        </div>
      {% endif %}

      {% if paginate.pages > 1 %}
        <nav class="vrai-pagination" aria-label="Blog pagination">
          {% if paginate.previous %}
            <a href="{{ paginate.previous.url }}">Prev</a>
          {% endif %}
          {% for part in paginate.parts %}
            {% if part.is_link %}
              <a href="{{ part.url }}">{{ part.title }}</a>
            {% elsif part.title == paginate.current_page %}
              <span class="current">{{ part.title }}</span>
            {% else %}
              <span>{{ part.title }}</span>
            {% endif %}
          {% endfor %}
          {% if paginate.next %}
            <a href="{{ paginate.next.url }}">Next</a>
          {% endif %}
        </nav>
      {% endif %}
    {% endpaginate %}
  </div>
</section>

{% schema %}
{
  "name": "Blog redesign",
  "settings": [],
  "presets": [
    {
      "name": "Blog redesign"
    }
  ]
}
{% endschema %}
