{{ 'store-redesign.css' | asset_url | stylesheet_tag }}
<script src="{{ 'store-redesign.js' | asset_url }}" defer></script>

<section class="vrai-store-page vrai-contact-page">
  <nav class="vrai-breadcrumbs" aria-label="Breadcrumb">
    <a href="{{ routes.root_url }}">Home</a>
    <span class="vrai-breadcrumbs__separator">/</span>
    <span aria-current="page">Contact</span>
  </nav>

  <header class="vrai-product__top vrai-reveal">
    <p class="vrai-store-page__eyebrow">Contact</p>
    <h1 class="vrai-store-page__title">{{ page.title }}</h1>
  </header>

  <div class="vrai-contact">
    <p class="vrai-contact__lead">Questions on fit, shipping, or custom sourcing? Send us a note and our team will reply shortly.</p>

    {% form 'contact', class: 'vrai-contact__form' %}
      {% if form.posted_successfully? %}
        <p class="vrai-contact__status vrai-contact__status--success">Thanks for reaching out. We received your message and will get back to you soon.</p>
      {% endif %}

      {% if form.errors %}
        <div class="vrai-contact__status vrai-contact__status--error">
          {{ form.errors | default_errors }}
        </div>
      {% endif %}

      <div class="vrai-contact__grid">
        <div class="vrai-contact__field">
          <label for="ContactFormName">Name</label>
          <input id="ContactFormName" type="text" name="contact[name]" value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}" autocomplete="name">
        </div>

        <div class="vrai-contact__field">
          <label for="ContactFormEmail">Email</label>
          <input id="ContactFormEmail" type="email" name="contact[email]" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" autocomplete="email" required>
        </div>

        <div class="vrai-contact__field vrai-contact__field--full">
          <label for="ContactFormPhone">Phone</label>
          <input id="ContactFormPhone" type="tel" name="contact[phone]" value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}" autocomplete="tel">
        </div>

        <div class="vrai-contact__field vrai-contact__field--full">
          <label for="ContactFormMessage">Message</label>
          <textarea id="ContactFormMessage" name="contact[body]" rows="7" required>{% if form.body %}{{ form.body }}{% endif %}</textarea>
        </div>
      </div>

      <button class="vrai-contact__submit" type="submit">Submit</button>
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Contact redesign",
  "settings": [],
  "presets": [
    {
      "name": "Contact redesign"
    }
  ]
}
{% endschema %}
