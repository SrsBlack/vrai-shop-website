{{ 'store-redesign.css' | asset_url | stylesheet_tag }}
<script src="{{ 'store-redesign.js' | asset_url }}" defer></script>

<section class="vrai-store-page vrai-edits">
  <nav class="vrai-breadcrumbs" aria-label="Breadcrumb">
    <a href="{{ routes.root_url }}">Home</a>
    <span class="vrai-breadcrumbs__separator">/</span>
    <span aria-current="page">The Edits</span>
  </nav>

  <header class="vrai-edits__head vrai-reveal">
    <span class="vrai-store-page__eyebrow">Curated Selections</span>
    <h1 class="vrai-store-page__title vrai-edits__title">The Edits</h1>
    <p class="vrai-store-page__lead">A visual archive of form and materiality. Each edit is a purposeful dialogue between contemporary silhouettes and timeless craft.</p>
  </header>

  <div class="vrai-edits__grid">
    {%- assign edit_index = 0 -%}
    {%- for collection in collections -%}
      {%- if collection.handle == 'frontpage' or collection.products_count == 0 -%}{%- continue -%}{%- endif -%}
      {%- assign layout_pos = edit_index | modulo: 5 -%}
      <a href="{{ collection.url }}" class="vrai-edits__card vrai-edits__card--pos{{ layout_pos }} vrai-reveal">
        <div class="vrai-edits__card-media">
          {%- if collection.image != blank -%}
            {{ collection.image | image_url: width: 1400 | image_tag: alt: collection.title, loading: 'lazy' }}
          {%- elsif collection.products.first.featured_image != blank -%}
            {{ collection.products.first.featured_image | image_url: width: 1400 | image_tag: alt: collection.title, loading: 'lazy' }}
          {%- else -%}
            {{ 'collection-2' | placeholder_svg_tag }}
          {%- endif -%}
        </div>
        <div class="vrai-edits__card-copy">
          <h2>{{ collection.title }}</h2>
          <span class="vrai-edits__issue">{{ collection.products_count }} pieces</span>
        </div>
        {%- if collection.description != blank -%}
          <p class="vrai-edits__card-desc">{{ collection.description | strip_html | truncatewords: 20 }}</p>
        {%- endif -%}
        <span class="vrai-edits__view-link">View Collection</span>
      </a>
      {%- assign edit_index = edit_index | plus: 1 -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection list redesign",
  "settings": [],
  "presets": [
    {
      "name": "Collection list redesign"
    }
  ]
}
{% endschema %}