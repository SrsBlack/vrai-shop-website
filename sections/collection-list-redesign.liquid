{{ 'store-redesign.css' | asset_url | stylesheet_tag }}
<script src="{{ 'store-redesign.js' | asset_url }}" defer></script>

<section class="vrai-store-page vrai-collection-list-page">
  <nav class="vrai-breadcrumbs" aria-label="Breadcrumb">
    <a href="{{ routes.root_url }}">Home</a>
    <span class="vrai-breadcrumbs__separator">/</span>
    <span aria-current="page">Collections</span>
  </nav>

  <header class="vrai-product__top vrai-reveal">
    <p class="vrai-store-page__eyebrow">Collections</p>
    <h1 class="vrai-store-page__title">Shop by collection</h1>
    <p class="vrai-store-page__lead">Curated edits for every mood, silhouette, and season.</p>
  </header>

  <div class="vrai-collection-list">
    {% if collections.size > 0 %}
      <div class="vrai-collection-list__grid">
        {% for collection in collections %}
          {% unless collection.handle == 'frontpage' %}
            <article class="vrai-collection-list__card">
              <a href="{{ collection.url }}">
                {% if collection.featured_image %}
                  {{ collection.featured_image | image_url: width: 980 | image_tag: alt: collection.title, loading: 'lazy' }}
                {% elsif collection.products.first and collection.products.first.featured_image %}
                  {{ collection.products.first.featured_image | image_url: width: 980 | image_tag: alt: collection.title, loading: 'lazy' }}
                {% else %}
                  {{ 'collection-2' | placeholder_svg_tag }}
                {% endif %}
              </a>

              <div class="vrai-collection-list__card-content">
                <h2 class="vrai-collection-list__title"><a href="{{ collection.url }}">{{ collection.title }}</a></h2>
                {% if collection.description != blank %}
                  <p class="vrai-collection-list__excerpt">{{ collection.description | strip_html | truncate: 120 }}</p>
                {% endif %}
                <p><a class="vrai-ghost-cta" href="{{ collection.url }}">Explore</a></p>
              </div>
            </article>
          {% endunless %}
        {% endfor %}
      </div>
    {% else %}
      <div class="vrai-empty-state">
        <p>Collections are coming soon.</p>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Collection list redesign",
  "settings": [],
  "presets": [
    {
      "name": "Collection list redesign"
    }
  ]
}
{% endschema %}
