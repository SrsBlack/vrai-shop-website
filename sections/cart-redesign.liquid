{{ 'store-redesign.css' | asset_url | stylesheet_tag }}
<script src="{{ 'store-redesign.js' | asset_url }}" defer></script>

<section class="vrai-store-page">
  <nav class="vrai-breadcrumbs" aria-label="Breadcrumb">
    <a href="{{ routes.root_url }}">Home</a>
    <span class="vrai-breadcrumbs__separator">/</span>
    <span aria-current="page">Cart</span>
  </nav>

  <header class="vrai-product__top vrai-reveal">
    <p class="vrai-store-page__eyebrow">Your Selection</p>
    <h1 class="vrai-store-page__title">Shopping Bag</h1>
    <p class="vrai-store-page__lead">{{ cart.item_count }} {{ cart.item_count | pluralize: 'piece', 'pieces' }} curated</p>
  </header>

  {%- if cart.item_count > 0 -%}
    {%- liquid
      assign free_shipping_threshold = 15000
      assign remaining_cents = free_shipping_threshold | minus: cart.total_price
      assign progress_pct = cart.total_price | times: 100 | divided_by: free_shipping_threshold
      if progress_pct > 100
        assign progress_pct = 100
      endif
    -%}
    <div class="vrai-shipping-progress">
      {%- if remaining_cents > 0 -%}
        <p class="vrai-shipping-progress__msg"><span class="material-symbols-outlined" aria-hidden="true">local_shipping</span> {{ remaining_cents | money }} from complimentary shipping</p>
      {%- else -%}
        <p class="vrai-shipping-progress__msg vrai-shipping-progress__msg--unlocked"><span class="material-symbols-outlined" aria-hidden="true">check_circle</span> Complimentary shipping unlocked</p>
      {%- endif -%}
      <div class="vrai-shipping-progress__bar" role="progressbar" aria-valuenow="{{ progress_pct }}" aria-valuemin="0" aria-valuemax="100" aria-label="Free shipping progress">
        <div class="vrai-shipping-progress__fill" style="width: {{ progress_pct }}%;"></div>
      </div>
    </div>
    <form action="{{ routes.cart_url }}" method="post" class="vrai-cart">
      <div class="vrai-cart__grid">
        <div class="vrai-cart__items">
          {%- for item in cart.items -%}
            <article class="vrai-cart__item">
              <a href="{{ item.url }}" class="vrai-cart__item-image">
                {%- if item.image != blank -%}
                  {{ item.image | image_url: width: 360 | image_tag: alt: item.product.title, loading: 'lazy' }}
                {%- endif -%}
              </a>
              <div class="vrai-cart__item-details">
                <p class="vrai-card__vendor">{{ item.product.vendor }}</p>
                <h2 class="vrai-cart__item-title"><a href="{{ item.url }}">{{ item.product.title }}</a></h2>
                {%- unless item.product.has_only_default_variant -%}
                  <p class="vrai-cart__item-variant">{{ item.variant.title }}</p>
                {%- endunless -%}
                <div class="vrai-cart__line-meta">
                  <div class="vrai-cart__qty-control">
                    <label class="visually-hidden" for="qty-{{ item.key }}">Quantity</label>
                    <input id="qty-{{ item.key }}" type="number" name="updates[{{ item.key }}]" value="{{ item.quantity }}" min="0" aria-label="Quantity for {{ item.product.title }}">
                  </div>
                  <span class="vrai-cart__line-price">{{ item.final_line_price | money }}</span>
                </div>
                <button type="button" class="vrai-cart__remove" onclick="window.location.href='{{ item.url_to_remove }}'">Remove</button>
              </div>
            </article>
          {%- endfor -%}
          <button class="vrai-homepage__button vrai-homepage__button--ghost" type="submit" name="update">Update bag</button>
        </div>

        <aside class="vrai-cart__summary">
          <h3 class="vrai-cart__summary-title">Order Summary</h3>
          <div class="vrai-cart__totals">
            <span>Subtotal</span>
            <strong>{{ cart.total_price | money }}</strong>
          </div>
          <p class="vrai-cart__summary-note">Taxes and shipping calculated at checkout.</p>
          <p class="vrai-cart__summary-note">Discount codes can be applied at checkout.</p>

          <div class="vrai-cart__cta">
            <button type="submit" name="checkout" class="vrai-homepage__button vrai-homepage__button--primary">Proceed to Checkout</button>
          </div>

          <ul class="vrai-cart__trust" aria-label="Shopping assurances">
            <li>
              <span class="material-symbols-outlined" aria-hidden="true">lock</span>
              Secure checkout
            </li>
            <li>
              <span class="material-symbols-outlined" aria-hidden="true">undo</span>
              Free returns
            </li>
            <li>
              <span class="material-symbols-outlined" aria-hidden="true">local_shipping</span>
              Tracked shipping
            </li>
          </ul>
        </aside>
      </div>
    </form>
  {%- else -%}
    <div class="vrai-empty-state">
      <span class="material-symbols-outlined vrai-empty-state__icon" aria-hidden="true">shopping_bag</span>
      <p>Your bag is empty.</p>
      <p class="vrai-store-page__lead">Explore the collection to find your next piece.</p>
      <a class="vrai-homepage__button vrai-homepage__button--primary" href="{{ routes.all_products_collection_url }}">Continue shopping</a>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Cart redesign",
  "settings": [],
  "presets": [
    {
      "name": "Cart redesign"
    }
  ]
}
{% endschema %}