{{ 'store-redesign.css' | asset_url | stylesheet_tag }}
<script src="{{ 'store-redesign.js' | asset_url }}" defer></script>

<section class="vrai-store-page">
  <nav class="vrai-breadcrumbs" aria-label="Breadcrumb">
    <a href="{{ routes.root_url }}">Home</a>
    <span class="vrai-breadcrumbs__separator">/</span>
    <span aria-current="page">Cart</span>
  </nav>

  <header class="vrai-product__top vrai-reveal">
    <p class="vrai-store-page__eyebrow">Checkout</p>
    <h1 class="vrai-store-page__title">Your cart</h1>
    <p class="vrai-store-page__lead">Secure checkout, complimentary shipping, and easy returns.</p>
  </header>

  {%- if cart.item_count > 0 -%}
    {%- liquid
      assign free_shipping_threshold = 15000
      assign remaining_cents = free_shipping_threshold | minus: cart.total_price
      assign progress_pct = cart.total_price | times: 100 | divided_by: free_shipping_threshold
      if progress_pct > 100
        assign progress_pct = 100
      endif
    -%}
    <div class="vrai-shipping-progress">
      {%- if remaining_cents > 0 -%}
        <p class="vrai-shipping-progress__msg">You're <strong>{{ remaining_cents | money }}</strong> away from <strong>free shipping</strong></p>
      {%- else -%}
        <p class="vrai-shipping-progress__msg vrai-shipping-progress__msg--unlocked">🎉 You've unlocked <strong>free shipping!</strong></p>
      {%- endif -%}
      <div class="vrai-shipping-progress__bar" role="progressbar" aria-valuenow="{{ progress_pct }}" aria-valuemin="0" aria-valuemax="100" aria-label="Free shipping progress">
        <div class="vrai-shipping-progress__fill" style="width: {{ progress_pct }}%;"></div>
      </div>
    </div>
    <form action="{{ routes.cart_url }}" method="post" class="vrai-cart">
      <div class="vrai-cart__grid">
        <div class="vrai-cart__items">
          {%- for item in cart.items -%}
            <article class="vrai-cart__item">
              <a href="{{ item.url }}">
                {%- if item.image != blank -%}
                  {{ item.image | image_url: width: 280 | image_tag: alt: item.product.title, loading: 'lazy' }}
                {%- endif -%}
              </a>
              <div>
                <p class="vrai-card__vendor">{{ item.product.vendor }}</p>
                <h2 class="vrai-cart__item-title"><a href="{{ item.url }}">{{ item.product.title }}</a></h2>
                {%- unless item.product.has_only_default_variant -%}
                  <p>{{ item.variant.title }}</p>
                {%- endunless -%}
                <div class="vrai-cart__line-meta">
                  <input type="number" name="updates[{{ item.key }}]" value="{{ item.quantity }}" min="0" aria-label="Quantity for {{ item.product.title }}">
                  <span>{{ item.final_line_price | money }}</span>
                </div>
                <a href="{{ item.url_to_remove }}" class="vrai-card__vendor">Remove</a>
              </div>
            </article>
          {%- endfor -%}
          <button class="vrai-homepage__button vrai-homepage__button--ghost" type="submit" name="update">Update cart</button>
        </div>

        <aside class="vrai-cart__summary">
          <p class="vrai-card__vendor">Order summary</p>
          <div class="vrai-cart__totals">
            <span>Subtotal</span>
            <strong>{{ cart.total_price | money }}</strong>
          </div>
          <p class="vrai-store-page__lead">Taxes and shipping are calculated at checkout.</p>

          <div class="vrai-cart__discount">
            <label for="CartDiscountCode" class="vrai-cart__discount-label">Discount code</label>
            <div class="vrai-cart__discount-row">
              <input id="CartDiscountCode" type="text" name="discount" placeholder="Enter code" class="vrai-cart__discount-input" autocomplete="off">
              <button type="submit" name="apply_discount" class="vrai-cart__discount-btn">Apply</button>
            </div>
          </div>

          <div class="vrai-cart__cta">
            <button type="submit" name="checkout" class="vrai-homepage__button vrai-homepage__button--primary">Checkout</button>
          </div>

          <ul class="vrai-cart__trust" aria-label="Shopping assurances">
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              Secure checkout
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
              Free returns
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              Tracked shipping
            </li>
          </ul>
        </aside>
      </div>
    </form>
  {%- else -%}
    <div class="vrai-empty-state">
      <p>Your cart is currently empty.</p>
      <a class="vrai-homepage__button vrai-homepage__button--primary" href="{{ routes.all_products_collection_url }}">Continue shopping</a>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Cart redesign",
  "settings": [],
  "presets": [
    {
      "name": "Cart redesign"
    }
  ]
}
{% endschema %}