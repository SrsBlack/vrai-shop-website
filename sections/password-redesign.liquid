{{ 'special-redesign.css' | asset_url | stylesheet_tag }}

<section class="vrai-password">
  <div class="vrai-password__panel">
    <p class="vrai-password__eyebrow">Private launch</p>
    <h1 class="vrai-password__title">VRAI opens soon.</h1>
    <p class="vrai-password__lead">A sharper edit is on the way. Join the list for first access to the live drop, private previews, and early availability.</p>

    {%- if shop.password_message != blank -%}
      <div class="vrai-password__message">{{ shop.password_message }}</div>
    {%- endif -%}

    {% form 'customer', class: 'vrai-password__form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">

      {% if form.posted_successfully? %}
        <p class="vrai-password__status vrai-password__status--success">You are on the list. We will let you know the moment the storefront opens.</p>
      {% endif %}

      {% if form.errors %}
        <div class="vrai-password__status vrai-password__status--error">{{ form.errors | default_errors }}</div>
      {% endif %}

      <label class="visually-hidden" for="PasswordNewsletterEmail">Email</label>
      <input
        id="PasswordNewsletterEmail"
        class="vrai-password__field"
        type="email"
        name="contact[email]"
        value="{% if customer %}{{ customer.email }}{% endif %}"
        placeholder="Email address"
        autocomplete="email"
        required
      >

      <button class="vrai-password__submit" type="submit">Notify me</button>
    {% endform %}

    <p class="vrai-password__hint">Store owner? Use the password entry below.</p>
    <p class="vrai-password__owner">Clients will land on a polished waitlist page until the store is ready to open publicly.</p>
  </div>
</section>

{% schema %}
{
  "name": "Password redesign",
  "settings": [],
  "presets": [
    {
      "name": "Password redesign"
    }
  ]
}
{% endschema %}
