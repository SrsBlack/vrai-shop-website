{{ 'store-redesign.css' | asset_url | stylesheet_tag }}
<script src="{{ 'store-redesign.js' | asset_url }}" defer></script>

{%- assign current_variant = product.selected_or_first_available_variant -%}

<section class="vrai-store-page vrai-product-page">
  <nav class="vrai-breadcrumbs" aria-label="Breadcrumb">
    <a href="{{ routes.root_url }}">Home</a>
    <span class="vrai-breadcrumbs__separator">/</span>
    {%- if product.collections.size > 0 -%}
      <a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a>
      <span class="vrai-breadcrumbs__separator">/</span>
    {%- endif -%}
    <span aria-current="page">{{ product.title | truncate: 40 }}</span>
  </nav>

  <header class="vrai-product__top vrai-reveal">
    <p class="vrai-store-page__eyebrow">Product</p>
    <h1 class="vrai-store-page__title">{{ product.title }}</h1>
  </header>

  <div class="vrai-product">
    <div class="vrai-product__gallery vrai-reveal">
      {%- if product.featured_image != blank -%}
        {%- assign featured_zoom_url = product.featured_image | image_url: width: 2200 -%}
        <button class="vrai-product__featured-trigger" type="button" data-vrai-open-zoom data-vrai-zoom-src="{{ featured_zoom_url }}" aria-label="Open enlarged image of {{ product.title | escape }}">
          {{ product.featured_image | image_url: width: 1400 | image_tag: alt: product.title, class: 'vrai-product__featured', loading: 'eager' }}
          <span class="vrai-product__zoom-hint" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
          </span>
        </button>
      {%- endif -%}

      {%- if product.images.size > 1 -%}
        <div class="vrai-product__thumbs">
          {%- for image in product.images limit: 8 -%}
            <button
              type="button"
              class="vrai-product__thumb{% if forloop.first %} is-active{% endif %}"
              data-vrai-thumb
              data-vrai-thumb-full="{{ image | image_url: width: 1400 }}"
              data-vrai-thumb-zoom="{{ image | image_url: width: 2200 }}"
              data-vrai-thumb-alt="{{ image.alt | default: product.title | escape }}"
              data-vrai-thumb-index="{{ forloop.index0 }}"
              aria-pressed="{% if forloop.first %}true{% else %}false{% endif %}"
              aria-label="Show image {{ forloop.index }} of {{ product.title | escape }}"
            >
              {{ image | image_url: width: 320 | image_tag: alt: image.alt | default: product.title, loading: 'lazy' }}
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
      <div class="vrai-product__swipe-hint" data-vrai-swipe-hint hidden aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </div>

      <div class="vrai-product__image-modal" data-vrai-image-modal hidden role="dialog" aria-modal="true" aria-label="Enlarged product image">
        <button type="button" class="vrai-product__image-modal-close" data-vrai-close-zoom aria-label="Close image preview">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
        <img class="vrai-product__modal-img" data-vrai-modal-image alt="">
      </div>
    </div>

    <div class="vrai-product__details vrai-reveal">
      <p class="vrai-product__vendor">{{ product.vendor }}</p>
      <h2 class="vrai-product__name">{{ product.title }}</h2>

      <p class="vrai-product__price">
        <span data-vrai-price>{{ current_variant.price | money }}</span>
        {%- if current_variant.compare_at_price > current_variant.price -%}
          <span class="vrai-card__compare" data-vrai-compare>{{ current_variant.compare_at_price | money }}</span>
          {%- assign savings_pct = current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price -%}
          <span class="vrai-product__save-badge">Save {{ savings_pct }}%</span>
        {%- else -%}
          <span class="vrai-card__compare" data-vrai-compare hidden></span>
        {%- endif -%}
      </p>

      {%- if current_variant.inventory_management != blank and current_variant.inventory_policy == 'deny' -%}
        {%- if current_variant.inventory_quantity > 0 and current_variant.inventory_quantity <= 5 -%}
          <p class="vrai-product__stock-urgency" data-vrai-stock-urgency>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            Only {{ current_variant.inventory_quantity }} left in stock
          </p>
        {%- endif -%}
      {%- endif -%}

      {%- form 'product', product, class: 'vrai-product__form' -%}
        {%- if product.variants.size > 1 -%}
          <div class="vrai-product__form-row">
            <label for="VariantSelect">Choose option</label>
            <select id="VariantSelect" name="id" data-vrai-variant-select>
              {%- for variant in product.variants -%}
                <option value="{{ variant.id }}" {% if variant.id == current_variant.id %}selected{% endif %} {% unless variant.available %}disabled{% endunless %}>
                  {{ variant.title }}{% unless variant.available %} - Sold out{% endunless %}
                </option>
              {%- endfor -%}
            </select>
          </div>
        {%- else -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}">
        {%- endif -%}

        <div class="vrai-product__form-row">
          <label for="Quantity">Quantity</label>
          <input id="Quantity" type="number" name="quantity" value="1" min="1">
        </div>

        <button type="button" class="vrai-product__size-guide-btn" data-vrai-size-guide-open>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/></svg>
          Size Guide
        </button>

        <button type="submit" data-vrai-submit {% unless current_variant.available %}disabled{% endunless %}>
          {% if current_variant.available %}Add to cart{% else %}Sold out{% endif %}
        </button>
        {{ form | payment_button }}
      {%- endform -%}

      {%- if product.description != blank -%}
        <div class="vrai-product__description rte">{{ product.description }}</div>
      {%- endif -%}
    </div>
  </div>

  <aside class="vrai-product__meta vrai-reveal">
    <h3>Fit and finish</h3>
    <p>Designed with elevated materials and made to style seamlessly from day to evening.</p>
    <h3>Shipping</h3>
    <p>Complimentary tracked shipping and easy returns on all orders.</p>
    <h3>Styling notes</h3>
    <p>Pair with minimal tailoring, tonal knitwear, and refined accessories for a complete look.</p>
  </aside>

  {%- comment -%} Related Products Carousel {%- endcomment -%}
  {%- if product.collections.size > 0 -%}
    {%- assign primary_collection = product.collections.first -%}
    {%- assign related_products = primary_collection.products | where_not: "id", product.id | limit: 8 -%}
    {%- if related_products.size > 0 -%}
    <section class="vrai-related vrai-reveal" aria-labelledby="related-heading">
      <h2 id="related-heading" class="vrai-related__title">You may also like</h2>
      <div class="vrai-related__carousel" data-vrai-carousel>
        <button class="vrai-related__nav vrai-related__nav--prev" data-vrai-carousel-prev aria-label="Previous products" disabled>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <div class="vrai-related__track" data-vrai-carousel-track>
          {%- for related in related_products -%}
            {%- assign related_variant = related.selected_or_first_available_variant -%}
            <article class="vrai-related__item">
              <a href="{{ related.url }}" class="vrai-related__link">
                {%- if related.featured_image -%}
                  {{ related.featured_image | image_url: width: 600 | image_tag: alt: related.title, class: 'vrai-related__image', loading: 'lazy' }}
                {%- endif -%}
                <div class="vrai-related__info">
                  <p class="vrai-related__vendor">{{ related.vendor }}</p>
                  <h3 class="vrai-related__name">{{ related.title | truncate: 60 }}</h3>
                  <p class="vrai-related__price">{{ related_variant.price | money }}</p>
                </div>
              </a>
            </article>
          {%- endfor -%}
        </div>
        <button class="vrai-related__nav vrai-related__nav--next" data-vrai-carousel-next aria-label="Next products">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
    </section>
    {%- endif -%}
  {%- endif -%}

  {%- comment -%} Reviews Section {%- endcomment -%}
  <section class="vrai-reviews vrai-reveal" data-vrai-reviews>
    <div class="vrai-reviews__header">
      <h2>Shopping Confidence</h2>
      <div class="vrai-reviews__summary">
        <p class="vrai-reviews__count">Verified customer reviews can be connected here once your review app is installed. Until then, we surface the service standards every VRAI order receives.</p>
        <a href="/pages/contact" class="vrai-reviews__write-btn">Ask a Product Question</a>
      </div>
    </div>
    <div class="vrai-reviews__list">
      <article class="vrai-review">
        <div class="vrai-review__header">
          <div class="vrai-review__meta">
            <span class="vrai-review__author">Fit Support</span>
            <span class="vrai-review__date">Before you buy</span>
          </div>
        </div>
        <h3 class="vrai-review__title">Size guidance stays one click away</h3>
        <p class="vrai-review__text">Every product page includes quick access to a size guide, clear variant selection, and direct support contact so shoppers can order with more confidence.</p>
        <span class="vrai-review__verified">Service standard</span>
      </article>
      <article class="vrai-review">
        <div class="vrai-review__header">
          <div class="vrai-review__meta">
            <span class="vrai-review__author">Delivery Promise</span>
            <span class="vrai-review__date">Every order</span>
          </div>
        </div>
        <h3 class="vrai-review__title">Tracked shipping with straightforward returns</h3>
        <p class="vrai-review__text">We highlight shipping expectations and returns up front so customers understand the post-purchase experience before they add to cart.</p>
        <span class="vrai-review__verified">Service standard</span>
      </article>
      <article class="vrai-review">
        <div class="vrai-review__header">
          <div class="vrai-review__meta">
            <span class="vrai-review__author">Editorial Curation</span>
            <span class="vrai-review__date">Updated regularly</span>
          </div>
        </div>
        <h3 class="vrai-review__title">A tighter edit, not a crowded catalog</h3>
        <p class="vrai-review__text">The redesigned product pages focus on imagery, styling notes, and related picks so customers can move through the storefront with less clutter and better context.</p>
        <span class="vrai-review__verified">Store standard</span>
      </article>
    </div>
    <p class="vrai-reviews__footnote">When you connect a reviews platform, this section can be swapped to live verified customer feedback without changing the page layout.</p>
  </section>

  {%- comment -%} Sticky Add to Cart (Mobile) {%- endcomment -%}
  <div class="vrai-sticky-atc" data-vrai-sticky-atc hidden>
    <div class="vrai-sticky-atc__inner">
      <div class="vrai-sticky-atc__info">
        <p class="vrai-sticky-atc__price" data-vrai-sticky-price>{{ current_variant.price | money }}</p>
      </div>
      <button type="button" class="vrai-sticky-atc__btn" data-vrai-sticky-submit>
        Add to cart
      </button>
    </div>
  </div>

  {%- comment -%} Size Guide Modal {%- endcomment -%}
  <div class="vrai-size-guide-modal" data-vrai-size-guide-modal hidden role="dialog" aria-modal="true" aria-labelledby="size-guide-title">
    <div class="vrai-size-guide__content">
      <button type="button" class="vrai-size-guide__close" data-vrai-size-guide-close aria-label="Close size guide">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
      <h2 id="size-guide-title">Size Guide</h2>
      <div class="vrai-size-guide__body">
        <div class="vrai-size-guide__tabs">
          <button class="vrai-size-guide__tab is-active" data-tab="womens">Women's</button>
          <button class="vrai-size-guide__tab" data-tab="mens">Men's</button>
        </div>
        <div class="vrai-size-guide__table" data-tab-content="womens">
          <table>
            <thead>
              <tr>
                <th>Size</th>
                <th>Bust (in)</th>
                <th>Waist (in)</th>
                <th>Hip (in)</th>
              </tr>
            </thead>
            <tbody>
              <tr><td>XS</td><td>30-32</td><td>24-26</td><td>34-36</td></tr>
              <tr><td>S</td><td>32-34</td><td>26-28</td><td>36-38</td></tr>
              <tr><td>M</td><td>34-36</td><td>28-30</td><td>38-40</td></tr>
              <tr><td>L</td><td>36-38</td><td>30-32</td><td>40-42</td></tr>
              <tr><td>XL</td><td>38-40</td><td>32-34</td><td>42-44</td></tr>
            </tbody>
          </table>
          <p class="vrai-size-guide__note">All measurements are approximate and may vary by style.</p>
        </div>
        <div class="vrai-size-guide__table" data-tab-content="mens" hidden>
          <table>
            <thead>
              <tr>
                <th>Size</th>
                <th>Chest (in)</th>
                <th>Waist (in)</th>
                <th>Sleeve (in)</th>
              </tr>
            </thead>
            <tbody>
              <tr><td>S</td><td>34-36</td><td>28-30</td><td>32-33</td></tr>
              <tr><td>M</td><td>36-38</td><td>30-32</td><td>33-34</td></tr>
              <tr><td>L</td><td>38-40</td><td>32-34</td><td>34-35</td></tr>
              <tr><td>XL</td><td>40-42</td><td>34-36</td><td>35-36</td></tr>
              <tr><td>XXL</td><td>42-44</td><td>36-38</td><td>36-37</td></tr>
            </tbody>
          </table>
          <p class="vrai-size-guide__note">All measurements are approximate and may vary by style.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script type="application/json" data-vrai-variants>
  {{ product.variants | json }}
</script>

{% schema %}
{
  "name": "Product redesign",
  "settings": [],
  "presets": [
    {
      "name": "Product redesign"
    }
  ]
}
{% endschema %}
