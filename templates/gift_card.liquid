{% layout none %}

<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    {%- render 'stylesheets' -%}
    {{ 'special-redesign.css' | asset_url | stylesheet_tag }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@500;600;700&display=swap">

    <script type="importmap">
      {
        "imports": {
          "@theme/component": "{{ 'component.js' | asset_url }}",
          "@theme/utilities": "{{ 'utilities.js' | asset_url }}",
          "@theme/qr-code-generator": "{{ 'qr-code-generator.js' | asset_url }}"
        }
      }
    </script>

    <script
      src="{{ 'qr-code-image.js' | asset_url }}"
      type="module"
      fetchpriority="low"
    ></script>
    <script
      src="{{ 'copy-to-clipboard.js' | asset_url }}"
      type="module"
      fetchpriority="low"
    ></script>
    <meta
      http-equiv="X-UA-Compatible"
      content="IE=edge"
    >
    <meta
      name="viewport"
      content="width=device-width,initial-scale=1"
    >
    <meta
      name="theme-color"
      content="{{ settings.color_schemes.scheme-1.settings.background }}"
    >
    <link
      rel="canonical"
      href="{{ canonical_url }}"
    >

    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {%- assign formatted_balance = gift_card.balance | money_without_trailing_zeros | strip_html -%}

    <title>{{ 'gift_cards.issued.title' | t: value: formatted_balance, shop: shop.name }}</title>

    <meta
      name="description"
      content="{{ 'gift_cards.issued.subtext' | t }}"
    >

    {{ content_for_header }}

    {% # theme-check-disable AssetPreload %}
    {%- unless settings.type_body_font.system? -%}
      <link
        rel="preload"
        as="font"
        href="{{ settings.type_body_font | font_url }}"
        type="font/woff2"
        crossorigin
        fetchpriority="low"
      >
    {%- endunless -%}
    {%- unless settings.type_subheading_font.system? -%}
      <link
        rel="preload"
        as="font"
        href="{{ settings.type_subheading_font | font_url }}"
        type="font/woff2"
        crossorigin
        fetchpriority="low"
      >
    {%- endunless -%}
    {%- unless settings.type_heading_font.system? -%}
      <link
        rel="preload"
        as="font"
        href="{{ settings.type_heading_font | font_url }}"
        type="font/woff2"
        crossorigin
        fetchpriority="low"
      >
    {%- endunless -%}
    {%- unless settings.type_accent_font.system? -%}
      <link
        rel="preload"
        as="font"
        href="{{ settings.type_accent_font | font_url }}"
        type="font/woff2"
        crossorigin
        fetchpriority="low"
      >
    {%- endunless -%}
    {% # theme-check-enable AssetPreload %}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}
  </head>

  <body class="gift-card vrai-gift-card">
    <main class="vrai-gift-card__wrap">
      <section class="vrai-gift-card__panel">
        <p class="vrai-gift-card__eyebrow">Gift card</p>
        <h1 class="vrai-gift-card__title">A refined credit for the next VRAI piece.</h1>
        <p class="vrai-gift-card__lead">Use this code online or scan the QR code in store to redeem the balance.</p>

        <div class="vrai-gift-card__grid">
          <div class="vrai-gift-card__card">
            <div class="vrai-gift-card__brand">
              <p class="vrai-gift-card__brand-name">{{ shop.name }}</p>
              <p class="vrai-gift-card__balance">{{ gift_card.balance | money_with_currency }}</p>
            </div>

            <div class="vrai-gift-card__card-image">
              {%- if settings.logo != blank -%}
                {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
                {{ settings.logo | image_url: width: 900 | image_tag: alt: logo_alt, loading: 'eager' }}
              {%- else -%}
                <img
                  src="{{ 'gift-card/card.svg' | shopify_asset_url }}"
                  alt="{{ shop.name | escape }} gift card"
                  height="200"
                  width="334"
                  loading="eager"
                >
              {%- endif -%}
            </div>
          </div>

          <div class="vrai-gift-card__details">
            {%- if gift_card.enabled == false or gift_card.expired -%}
              <p class="vrai-gift-card__status vrai-gift-card__status--expired">{{ 'gift_cards.issued.expired' | t }}</p>
            {%- else -%}
              <p class="vrai-gift-card__status vrai-gift-card__status--active">Ready to redeem</p>
            {%- endif -%}

            {% if gift_card.expires_on %}
              {%- assign gift_card_expiration_date = gift_card.expires_on | date: '%B %e, %Y' -%}
              <p class="vrai-gift-card__text">{{ 'gift_cards.issued.expiration_date' | t: expires_on: gift_card_expiration_date }}</p>
            {% endif %}

            <div class="vrai-gift-card__meta">
              <p class="vrai-gift-card__text">{{ 'gift_cards.issued.how_to_use_gift_card' | t }}</p>
              <div class="vrai-gift-card__code">{{ gift_card.code | format_code }}</div>
              <div class="vrai-gift-card__qr">
                <qr-code-image
                  data-identifier="{{ gift_card.qr_identifier }}"
                  width="96"
                  height="96"
                  alt="{{ 'gift_cards.issued.qr_image_alt' | t }}"
                ></qr-code-image>
              </div>
            </div>

            <div class="vrai-gift-card__actions">
              {%- if gift_card.pass_url -%}
                <a href="{{ gift_card.pass_url }}" class="vrai-gift-card__wallet">
                  <img
                    src="{{ 'gift-card/add-to-apple-wallet.svg' | shopify_asset_url }}"
                    width="120"
                    height="40"
                    alt="{{ 'gift_cards.issued.add_to_apple_wallet' | t }}"
                    loading="lazy"
                  >
                </a>
              {%- endif -%}

              <copy-to-clipboard-component text-to-copy="{{ gift_card.code }}">
                <span class="form__message visually-hidden" ref="copySuccessMessage" role="status">
                  <span class="svg-wrapper icon-success">
                    {{ 'icon-checkmark.svg' | inline_asset_content }}
                  </span>
                  {{ 'gift_cards.issued.copy_code_success' | t }}
                </span>
                <button class="vrai-gift-card__button" on:click="/copyToClipboard">
                  {{ 'gift_cards.issued.copy_code' | t }}
                </button>
              </copy-to-clipboard-component>

              <a
                href="{{ shop.url }}"
                class="vrai-gift-card__button-secondary"
                target="_blank"
                rel="noopener"
                aria-describedby="a11y-new-window-message"
              >
                {{ 'gift_cards.issued.shop_link' | t }}
              </a>
            </div>
          </div>
        </div>

        <p class="vrai-gift-card__footer">Redeem online at checkout or present the QR code in store.</p>
      </section>
    </main>

    <div hidden>
      <span id="a11y-new-window-message">{{ 'accessibility.new_window' | t }}</span>
    </div>
  </body>
</html>
